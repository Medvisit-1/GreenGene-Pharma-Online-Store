# Copy to .env and fill in. NEVER commit the real .env.

# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Brand
NEXT_PUBLIC_SITE_NAME="GreenGene Pharma"
NEXT_PUBLIC_CURRENCY="ZAR"

# Admin login
ADMIN_EMAIL="admin@greengenepharma.co.za"
ADMIN_PASSWORD="change-me"
# Long random string used to sign the admin session cookie
SESSION_SECRET="generate-a-long-random-string"

# Public base URL of the deployed site (used for payment redirect/return links)
APP_URL="https://your-domain.co.za"

# ---- Payment gateways ----
# Yoco (https://www.yoco.com)
YOCO_SECRET_KEY=""
YOCO_WEBHOOK_SECRET=""

# Bob Go — shipping/fulfilment
BOBGO_API_HOST="https://api.bobgo.co.za"
BOBGO_API_KEY=""

# Bob Pay — host: sandbox=https://api.sandbox.bobpay.co.za  prod=https://api.bobpay.co.za
BOBPAY_API_HOST="https://api.bobpay.co.za"
BOBPAY_API_KEY=""
BOBPAY_EMAIL=""
BOBPAY_PASSWORD=""
BOBPAY_ACCOUNT_CODE=""
BOBPAY_PASSPHRASE=""
